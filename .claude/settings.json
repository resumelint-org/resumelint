{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/hooks/block_commit.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/hooks/reuse_surface_reminder.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/hooks/format_typescript.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/hooks/check_conventions.py"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/hooks/style_guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/hooks/lint_and_test.sh"
          }
        ]
      }
    ]
  }
}
