# Deploy configuration — copy to .env.deploy and fill in the values you need.
# .env.deploy is gitignored.

# Required. GCP project that owns the bucket, and the bucket name itself.
PROJECT_ID=your-gcp-project-id
BUCKET_NAME=your-bucket-name.example.com

# Optional. Set VITE_POSTHOG_KEY to instrument the deployed build per
# src/lib/analytics.ts. Leave commented out for the OSS no-analytics build
# (the posthog-js import is dead-code-eliminated when the key is unset).
# VITE_POSTHOG_KEY=phc_xxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com
