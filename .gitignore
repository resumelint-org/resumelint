COMMIT_EDITMSG
node_modules/
dist/
.env.local
.env.*.local
.env
.env.example
.env.deploy
.last_deploy_timestamp
*.log
.DS_Store

# Test coverage output (generated by `npm run test:coverage`; consumed by the
# fallow audit step in CI for accurate CRAP scoring).
coverage/

# Claude Code: ship settings.json (shared hooks for contributors),
# keep local-only state out.
.claude/worktrees/
.claude/settings.local.json

# Python bytecode cache from hook scripts under scripts/hooks/.
__pycache__/

# fallow audit output (runtime reports + latest.json symlink). The hook
# script .claude/hooks/fallow-stop.sh that writes this dir IS tracked.
.fallow/

# Local editor / workspace files (per-machine, never shared).
*.code-workspace
.idea/

# CodeGraph local index — config.json is tracked; the on-disk index is not.
# Mirrored here (not only in .codegraph/.gitignore) so editors that read just
# the root ignore file don't surface these as changes.
.codegraph/*.db
.codegraph/*.db-shm
.codegraph/*.db-wal
.codegraph/cache/
.codegraph/.dirty
.codegraph/*.pid

# Playwright MCP snapshot artifacts
.playwright-mcp/

# Local symlinks into ~/tools/scripts/ (shared bash helpers). Tracked as
# absolute-path symlinks they leaked the maintainer's home dir and were dead
# for anyone else. Keep them on disk for local dev/deploy; don't track them.
/scripts/common.sh
/scripts/deploy_web_utils.sh
/scripts/load_env.sh
